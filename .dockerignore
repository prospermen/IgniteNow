# =============================================================================
# Docker Ignore File for IgniteNow
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
!deploy/DOCKER.md
docs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
artifacts/

# Node modules (will be installed in container)
frontend/node_modules/
frontend/admin_web/node_modules/
node_modules/

# Test files
*_test.go
**/*.test.js
tests/
coverage/
.nyc_output/

# Environment files
.env
.env.*
!.env.example

# Local config
config.yaml
config.local.yaml

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
.venv*/
backend/.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Deploy files (not needed in image)
deploy/install.sh
deploy/sub2api.service
deploy/sub2api-sudoers
deploy/data/
deploy/postgres_data/
deploy/redis_data/

# GoReleaser
.goreleaser.yaml

# GitHub
.github/

# Claude files
.claude/
issues/
CLAUDE.md
