# Docker Compose host ports
APP_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL container credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ignitenow

# SQLite 示例：DATABASE_URL=sqlite:///./ignitenow.db
# 如果修改了 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB，DATABASE_URL 也要同步修改。
DATABASE_URL=postgresql://postgres:password@postgres:5432/ignitenow
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
STATIC_BASE_URL=http://localhost:8000/static
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=ignitenow
LLM_TIMEOUT_SECONDS=90
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
VITE_API_BASE_URL=http://localhost:8000
