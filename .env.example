# Docker Compose host ports
APP_PORT=8000
STATIC_BASE_URL=http://localhost:8000/static
VITE_API_BASE_URL=http://localhost:8000
# Docker Compose 内部访问 postgres 服务时使用这个地址。
# 如果修改了 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB，DATABASE_URL 也要同步修改。
# 本机直接运行后端时改为：postgresql://postgres:your_secure_password_here@localhost:5432/ignitenow
# 只想本地跑 SQLite 改为：sqlite:///./backend/ignitenow.db
DATABASE_URL=sqlite:///./backend/ignitenow.db

REDIS_PORT=6379
# Docker Compose 内部访问 redis 服务时使用这个地址；
# 本机直接运行后端时改为 redis://localhost:6379/0。
REDIS_URL=redis://redis:6379/0

POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ignitenow

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

RQ_QUEUE_NAME=ignitenow

LLM_TIMEOUT_SECONDS=90
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
